{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "brndle/hero",
  "title": "Hero Section",
  "category": "brndle-sections",
  "description": "Full-width hero section with eyebrow, headline, subtitle, CTAs, image, and logo strip.",
  "keywords": [
    "hero",
    "banner",
    "landing"
  ],
  "textdomain": "brndle",
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": ""
    },
    "title": {
      "type": "string",
      "default": ""
    },
    "subtitle": {
      "type": "string",
      "default": ""
    },
    "cta_primary": {
      "type": "string",
      "default": ""
    },
    "cta_primary_url": {
      "type": "string",
      "default": "#"
    },
    "cta_secondary": {
      "type": "string",
      "default": ""
    },
    "cta_secondary_url": {
      "type": "string",
      "default": "#"
    },
    "image": {
      "type": "string",
      "default": ""
    },
    "image_id": {
      "type": "number",
      "default": 0
    },
    "image_alt": {
      "type": "string",
      "default": ""
    },
    "variant": {
      "type": "string",
      "default": "dark",
      "enum": [
        "dark",
        "light",
        "gradient"
      ]
    },
    "logos": {
      "type": "array",
      "default": []
    }
  },
  "supports": {
    "align": [
      "full"
    ],
    "html": false,
    "anchor": true
  },
  "example": {
    "attributes": {
      "eyebrow": "New release",
      "title": "Build sites that just work.",
      "subtitle": "An enterprise-grade theme with AI-powered landing pages, server-rendered blocks, and a Lighthouse-100 baseline.",
      "cta_primary": "Start free trial",
      "cta_primary_url": "#",
      "cta_secondary": "View demo",
      "cta_secondary_url": "#",
      "variant": "dark"
    }
  },
  "version": "1.0.0",
  "variations": [
    {
      "name": "hero-dark",
      "title": "Hero — Dark",
      "description": "Full-width hero on a dark surface.",
      "attributes": {
        "variant": "dark"
      },
      "scope": [
        "inserter"
      ],
      "isDefault": true
    },
    {
      "name": "hero-light",
      "title": "Hero — Light",
      "description": "Full-width hero on a light surface.",
      "attributes": {
        "variant": "light"
      },
      "scope": [
        "inserter"
      ]
    },
    {
      "name": "hero-gradient",
      "title": "Hero — Gradient",
      "description": "Full-width hero with the brand accent gradient.",
      "attributes": {
        "variant": "gradient"
      },
      "scope": [
        "inserter"
      ]
    }
  ]
}
