{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "brndle/cta",
  "title": "CTA Section",
  "category": "brndle-sections",
  "description": "Call-to-action section with headline, subtitle, and buttons.",
  "keywords": ["cta", "call-to-action", "banner"],
  "textdomain": "brndle",
  "attributes": {
    "title": { "type": "string", "default": "" },
    "subtitle": { "type": "string", "default": "" },
    "cta_primary": { "type": "string", "default": "" },
    "cta_primary_url": { "type": "string", "default": "#" },
    "cta_secondary": { "type": "string", "default": "" },
    "cta_secondary_url": { "type": "string", "default": "#" },
    "variant": { "type": "string", "default": "dark" }
  },
  "supports": { "align": ["full"], "html": false, "anchor": true },
  "render": "file:./render.blade.php"
}
